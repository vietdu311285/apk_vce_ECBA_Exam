# ============================================
# .env.example — Mẫu biến môi trường
# ============================================
# HƯỚNG DẪN:
# 1. Copy file này: cp .env.example .env
# 2. Điền giá trị thật vào file .env
# 3. KHÔNG bao giờ commit file .env lên Git!
# ============================================

# --- App Settings ---
APP_NAME=MyApp
APP_ENV=development         # development | staging | production
APP_PORT=8000
DEBUG=true                  # Đặt false trên production

# --- Database ---
DATABASE_URL=sqlite:///./app.db
# Ví dụ PostgreSQL: postgresql://user:password@localhost:5432/dbname

# --- Security ---
SECRET_KEY=your-secret-key-change-this-in-production
JWT_EXPIRE_HOURS=24

# --- External APIs (điền key thật vào .env) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SENDGRID_API_KEY=

# --- Storage (nếu dùng) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# --- Logging ---
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
